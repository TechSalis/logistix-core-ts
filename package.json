{
  "name": "logistix-core-ts",
  "version": "1.0.0",
  "description": "Shared TypeScript types, enums, config, and utilities for all Logistix services",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "npx -y tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "npx -y tsup src/index.ts --format esm,cjs --dts --watch",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "DATABASE_URL=postgresql://dummy:dummy@localhost/dummy drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate:dev": "dotenv -e .env.development -- tsx scripts/migrate.ts",
    "db:migrate:staging": "dotenv -e .env.staging -- tsx scripts/migrate.ts",
    "db:migrate:prod": "dotenv -e .env.production -- tsx scripts/migrate.ts",
    "db:seed:dev": "dotenv -e .env.development -- tsx scripts/seed.ts",
    "db:seed:staging": "dotenv -e .env.staging -- tsx scripts/seed.ts",
    "db:seed:prod": "dotenv -e .env.production -- tsx scripts/seed.ts",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build && (husky || true)"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run --passWithNoTests"
    ]
  },
  "keywords": [
    "logistix",
    "shared",
    "types",
    "enums"
  ],
  "author": "TechSalis",
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "dotenv-cli": "^7.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "postgres": "^3.4.4",
    "prettier": "^3.8.4",
    "tsup": "^8.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  }
}
